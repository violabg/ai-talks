# 1. Load the plugin
# @plugin(@varlock/pass-plugin)
#
# 2. Initialize the plugin - no arguments needed for default setup
# @initPass()
# @generateTypes(lang='ts', path='env.d.ts')
# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# 
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# # ----------
# @currentEnv=$APP_ENV
# ---
# @type=enum(development, preview, production)
VERCEL_ENV=
# @type=enum(development, preview, production, test)
APP_ENV=fallback($VERCEL_ENV, development)
# ----------

# items added to schema by `varlock init`
# that were missing in example, but detected in other .env files
# PLEASE REVIEW THESE!
# ---
# @type=url
BETTER_AUTH_URL="http://localhost:3000"
# @sensitive
BETTER_AUTH_SECRET=pass("ai-talks/BETTER_AUTH_SECRET")
GITHUB_CLIENT_ID="your_github_client_id"
# @sensitive
GITHUB_CLIENT_SECRET=pass("ai-talks/GITHUB_CLIENT_SECRET")
# @sensitive
KV_REST_API_READ_ONLY_TOKEN=pass("ai-talks/KV_REST_API_READ_ONLY_TOKEN")
# @sensitive
KV_REST_API_TOKEN=pass("ai-talks/KV_REST_API_TOKEN")
# @type=url
KV_REST_API_URL="http://your_kv_rest_api_url"
# @type=url
# @sensitive
KV_URL=concat("rediss://default:", ref("KV_REST_API_TOKEN"), "@living-hound-69957.upstash.io:6379")
# @type=url
# @sensitive
REDIS_URL=concat("rediss://default:", ref("KV_REST_API_TOKEN"), "@living-hound-69957.upstash.io:6379")
# @sensitive
VERCEL_OIDC_TOKEN="your_vercel_oidc_token"